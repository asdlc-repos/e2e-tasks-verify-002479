{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011tQuuSdFshaLwoBR9FhPEF","type":"tool_result","content":"1\timport { Task, Category } from '../types';\n2\t\n3\tconst API_BASE = import.meta.env.VITE_API_URL || '/api';\n4\t\n5\tlet token: string | null = null;\n6\t\n7\texport function setToken(t: string | null) {\n8\t  token = t;\n9\t}\n10\t\n11\texport function getToken(): string | null {\n12\t  return token;\n13\t}\n14\t\n15\tasync function request<T>(path: string, options: RequestInit = {}): Promise<T> {\n16\t  const headers: Record<string, string> = {\n17\t    'Content-Type': 'application/json',\n18\t    ...(options.headers as Record<string, string> || {}),\n19\t  };\n20\t  if (token) {\n21\t    headers['Authorization'] = `Bearer ${token}`;\n22\t  }\n23\t  const res = await fetch(`${API_BASE}${path}`, { ...options, headers });\n24\t  if (res.status === 204) return undefined as T;\n25\t  if (!res.ok) {\n26\t    const body = await res.text();\n27\t    let message: string;\n28\t    try {\n29\t      const json = JSON.parse(body);\n30\t      message = json.error || json.message || res.statusText;\n31\t    } catch {\n32\t      message = body || res.statusText;\n33\t    }\n34\t    throw new Error(message);\n35\t  }\n36\t  return res.json();\n37\t}\n38\t\n39\t// Auth\n40\texport async function login(email: string, password: string): Promise<string> {\n41\t  const data = await request<{ token: string }>('/auth/login', {\n42\t    method: 'POST',\n43\t    body: JSON.stringify({ email, password }),\n44\t  });\n45\t  return data.token;\n46\t}\n47\t\n48\texport async function register(email: string, password: string): Promise<void> {\n49\t  await request<void>('/auth/register', {\n50\t    method: 'POST',\n51\t    body: JSON.stringify({ email, password }),\n52\t  });\n53\t}\n54\t\n55\texport async function resetPassword(email: string): Promise<void> {\n56\t  await request<void>('/auth/reset-password', {\n57\t    method: 'POST',\n58\t    body: JSON.stringify({ email }),\n59\t  });\n60\t}\n61\t\n62\t// Tasks\n63\texport interface TaskFilters {\n64\t  status?: 'all' | 'active' | 'completed';\n65\t  category_id?: string;\n66\t  search?: string;\n67\t  sort?: 'due_date' | 'created_at';\n68\t}\n69\t\n70\texport async function getTasks(filters: TaskFilters = {}): Promise<Task[]> {\n71\t  const params = new URLSearchParams();\n72\t  if (filters.status && filters.status !== 'all') params.set('status', filters.status);\n73\t  if (filters.category_id) params.set('category_id', filters.category_id);\n74\t  if (filters.search) params.set('search', filters.search);\n75\t  if (filters.sort) params.set('sort', filters.sort);\n76\t  const qs = params.toString();\n77\t  return request<Task[]>(`/tasks${qs ? '?' + qs : ''}`);\n78\t}\n79\t\n80\texport async function createTask(data: { title: string; description?: string; category_id?: string; due_date?: string }): Promise<Task> {\n81\t  return request<Task>('/tasks', {\n82\t    method: 'POST',\n83\t    body: JSON.stringify(data),\n84\t  });\n85\t}\n86\t\n87\texport async function updateTask(id: string, data: Partial<Pick<Task, 'title' | 'description' | 'category_id' | 'due_date' | 'completed'>>): Promise<Task> {\n88\t  return request<Task>(`/tasks/${id}`, {\n89\t    method: 'PUT',\n90\t    body: JSON.stringify(data),\n91\t  });\n92\t}\n93\t\n94\texport async function deleteTask(id: string): Promise<void> {\n95\t  await request<void>(`/tasks/${id}`, { method: 'DELETE' });\n96\t}\n97\t\n98\t// Categories\n99\texport async function getCategories(): Promise<Category[]> {\n100\t  return request<Category[]>('/categories');\n101\t}\n102\t\n103\texport async function createCategory(name: string): Promise<Category> {\n104\t  return request<Category>('/categories', {\n105\t    method: 'POST',\n106\t    body: JSON.stringify({ name }),\n107\t  });\n108\t}\n109\t\n110\texport async function updateCategory(id: string, name: string): Promise<Category> {\n111\t  return request<Category>(`/categories/${id}`, {\n112\t    method: 'PUT',\n113\t    body: JSON.stringify({ name }),\n114\t  });\n115\t}\n116\t\n117\texport async function deleteCategory(id: string): Promise<void> {\n118\t  await request<void>(`/categories/${id}`, { method: 'DELETE' });\n119\t}\n120\t"}]},"parent_tool_use_id":null,"session_id":"4f9ade0c-31d4-4ddc-8da4-30caee42e277","uuid":"2034a489-d66b-47aa-ba9c-ee367d98510a","timestamp":"2026-04-26T04:07:08.236Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/wso2/asdlc-workspace/default/my-tasks/tasks-web/src/api/client.ts","content":"import { Task, Category } from '../types';\n\nconst API_BASE = import.meta.env.VITE_API_URL || '/api';\n\nlet token: string | null = null;\n\nexport function setToken(t: string | null) {\n  token = t;\n}\n\nexport function getToken(): string | null {\n  return token;\n}\n\nasync function request<T>(path: string, options: RequestInit = {}): Promise<T> {\n  const headers: Record<string, string> = {\n    'Content-Type': 'application/json',\n    ...(options.headers as Record<string, string> || {}),\n  };\n  if (token) {\n    headers['Authorization'] = `Bearer ${token}`;\n  }\n  const res = await fetch(`${API_BASE}${path}`, { ...options, headers });\n  if (res.status === 204) return undefined as T;\n  if (!res.ok) {\n    const body = await res.text();\n    let message: string;\n    try {\n      const json = JSON.parse(body);\n      message = json.error || json.message || res.statusText;\n    } catch {\n      message = body || res.statusText;\n    }\n    throw new Error(message);\n  }\n  return res.json();\n}\n\n// Auth\nexport async function login(email: string, password: string): Promise<string> {\n  const data = await request<{ token: string }>('/auth/login', {\n    method: 'POST',\n    body: JSON.stringify({ email, password }),\n  });\n  return data.token;\n}\n\nexport async function register(email: string, password: string): Promise<void> {\n  await request<void>('/auth/register', {\n    method: 'POST',\n    body: JSON.stringify({ email, password }),\n  });\n}\n\nexport async function resetPassword(email: string): Promise<void> {\n  await request<void>('/auth/reset-password', {\n    method: 'POST',\n    body: JSON.stringify({ email }),\n  });\n}\n\n// Tasks\nexport interface TaskFilters {\n  status?: 'all' | 'active' | 'completed';\n  category_id?: string;\n  search?: string;\n  sort?: 'due_date' | 'created_at';\n}\n\nexport async function getTasks(filters: TaskFilters = {}): Promise<Task[]> {\n  const params = new URLSearchParams();\n  if (filters.status && filters.status !== 'all') params.set('status', filters.status);\n  if (filters.category_id) params.set('category_id', filters.category_id);\n  if (filters.search) params.set('search', filters.search);\n  if (filters.sort) params.set('sort', filters.sort);\n  const qs = params.toString();\n  return request<Task[]>(`/tasks${qs ? '?' + qs : ''}`);\n}\n\nexport async function createTask(data: { title: string; description?: string; category_id?: string; due_date?: string }): Promise<Task> {\n  return request<Task>('/tasks', {\n    method: 'POST',\n    body: JSON.stringify(data),\n  });\n}\n\nexport async function updateTask(id: string, data: Partial<Pick<Task, 'title' | 'description' | 'category_id' | 'due_date' | 'completed'>>): Promise<Task> {\n  return request<Task>(`/tasks/${id}`, {\n    method: 'PUT',\n    body: JSON.stringify(data),\n  });\n}\n\nexport async function deleteTask(id: string): Promise<void> {\n  await request<void>(`/tasks/${id}`, { method: 'DELETE' });\n}\n\n// Categories\nexport async function getCategories(): Promise<Category[]> {\n  return request<Category[]>('/categories');\n}\n\nexport async function createCategory(name: string): Promise<Category> {\n  return request<Category>('/categories', {\n    method: 'POST',\n    body: JSON.stringify({ name }),\n  });\n}\n\nexport async function updateCategory(id: string, name: string): Promise<Category> {\n  return request<Category>(`/categories/${id}`, {\n    method: 'PUT',\n    body: JSON.stringify({ name }),\n  });\n}\n\nexport async function deleteCategory(id: string): Promise<void> {\n  await request<void>(`/categories/${id}`, { method: 'DELETE' });\n}\n","numLines":120,"startLine":1,"totalLines":120}}}
