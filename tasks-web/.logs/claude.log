{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NHmWLvjp2KDjZHVkJbbyAd","type":"tool_result","content":"1\timport { BrowserRouter, Routes, Route, Navigate } from 'react-router-dom';\n2\timport { AuthProvider, useAuth } from './context/AuthContext';\n3\timport { ToastProvider } from './context/ToastContext';\n4\timport LoginPage from './pages/LoginPage';\n5\timport RegisterPage from './pages/RegisterPage';\n6\timport ResetPasswordPage from './pages/ResetPasswordPage';\n7\timport DashboardPage from './pages/DashboardPage';\n8\t\n9\tfunction PrivateRoute({ children }: { children: JSX.Element }) {\n10\t  const { isAuthenticated } = useAuth();\n11\t  return isAuthenticated ? children : <Navigate to=\"/login\" replace />;\n12\t}\n13\t\n14\tfunction PublicRoute({ children }: { children: JSX.Element }) {\n15\t  const { isAuthenticated } = useAuth();\n16\t  return isAuthenticated ? <Navigate to=\"/\" replace /> : children;\n17\t}\n18\t\n19\texport default function App() {\n20\t  return (\n21\t    <BrowserRouter>\n22\t      <AuthProvider>\n23\t        <ToastProvider>\n24\t          <Routes>\n25\t            <Route path=\"/login\" element={<PublicRoute><LoginPage /></PublicRoute>} />\n26\t            <Route path=\"/register\" element={<PublicRoute><RegisterPage /></PublicRoute>} />\n27\t            <Route path=\"/reset-password\" element={<PublicRoute><ResetPasswordPage /></PublicRoute>} />\n28\t            <Route path=\"/\" element={<PrivateRoute><DashboardPage /></PrivateRoute>} />\n29\t            <Route path=\"*\" element={<Navigate to=\"/\" replace />} />\n30\t          </Routes>\n31\t        </ToastProvider>\n32\t      </AuthProvider>\n33\t    </BrowserRouter>\n34\t  );\n35\t}\n36\t"}]},"parent_tool_use_id":null,"session_id":"4f9ade0c-31d4-4ddc-8da4-30caee42e277","uuid":"58a8bf8f-31a5-45d9-90b8-f0d642923631","timestamp":"2026-04-26T04:07:09.023Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/wso2/asdlc-workspace/default/my-tasks/tasks-web/src/App.tsx","content":"import { BrowserRouter, Routes, Route, Navigate } from 'react-router-dom';\nimport { AuthProvider, useAuth } from './context/AuthContext';\nimport { ToastProvider } from './context/ToastContext';\nimport LoginPage from './pages/LoginPage';\nimport RegisterPage from './pages/RegisterPage';\nimport ResetPasswordPage from './pages/ResetPasswordPage';\nimport DashboardPage from './pages/DashboardPage';\n\nfunction PrivateRoute({ children }: { children: JSX.Element }) {\n  const { isAuthenticated } = useAuth();\n  return isAuthenticated ? children : <Navigate to=\"/login\" replace />;\n}\n\nfunction PublicRoute({ children }: { children: JSX.Element }) {\n  const { isAuthenticated } = useAuth();\n  return isAuthenticated ? <Navigate to=\"/\" replace /> : children;\n}\n\nexport default function App() {\n  return (\n    <BrowserRouter>\n      <AuthProvider>\n        <ToastProvider>\n          <Routes>\n            <Route path=\"/login\" element={<PublicRoute><LoginPage /></PublicRoute>} />\n            <Route path=\"/register\" element={<PublicRoute><RegisterPage /></PublicRoute>} />\n            <Route path=\"/reset-password\" element={<PublicRoute><ResetPasswordPage /></PublicRoute>} />\n            <Route path=\"/\" element={<PrivateRoute><DashboardPage /></PrivateRoute>} />\n            <Route path=\"*\" element={<Navigate to=\"/\" replace />} />\n          </Routes>\n        </ToastProvider>\n      </AuthProvider>\n    </BrowserRouter>\n  );\n}\n","numLines":36,"startLine":1,"totalLines":36}}}
